## ================================
## .NET / C# Standard GitIgnore
## ================================

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio / Rider / VS Code
.vs/
.vscode/
.idea/
*.swp
*.sln.ide

# Dotnet tooling
.project
.settings/
*.DotSettings.user

# Test results
TestResults/
*.trx
coverage/
coverage.xml
*.coverage
*.coveragexml

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/
project.lock.json
project.assets.json

# ASP.NET Core
appsettings.Development.json
appsettings.Local.json

# Azure / Secrets
secrets.json
*.pfx
*.cer
*.key
*.pem
*.crt

# Environment variables
.env
.env.*

# Publish output
publish/
artifacts/

# IIS / hosting
wwwroot/lib/
wwwroot/dist/

# Logs & runtime
*.log
*.pid
*.seed

# OS generated
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
desktop.ini

# ReSharper / Rider
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings

# JetBrains Rider
.idea/

# VS Code local history
.history/

# NCrunch
*.ncrunch*
.ncrunchproject

# SQL / LocalDB
*.mdf
*.ldf

# Temporary files
*.tmp
*.temp
*.bak
*.old

# Paket
.paket/
paket-files/

# MonoDevelop
*.pidb
*.userprefs

# Azure Functions local
local.settings.json

# Node (if you use frontend in same repo)
node_modules/
dist/
build/

# Generated swagger / clients
swagger.json
swagger.yaml
